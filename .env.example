# Azure OpenAI Environment Variables
# Copy this file to .env and fill in your values, or export these as shell variables.

# Azure OpenAI resource endpoint (include trailing slash)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-api-key-here

# Name of your model deployment in Azure OpenAI Studio
AZURE_OPENAI_DEPLOYMENT=gpt-4

# API version to use
AZURE_OPENAI_API_VERSION=2024-02-01

# (Optional) Maximum tokens for the generated description
AZURE_OPENAI_MAX_TOKENS=800

# (Optional) Creativity level: 0.0 (focused) – 1.0 (creative)
AZURE_OPENAI_TEMPERATURE=0.7
